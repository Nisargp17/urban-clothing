# ============================================================
# Urban Clothing — Frontend Environment Variables
# Copy to `.env` (local) and set in your host (Vercel) for prod.
# Only VITE_-prefixed vars are exposed to the client bundle.
# ============================================================

# Base URL of your backend REST API (no trailing slash needed)
VITE_API_URL=http://localhost:5000/api

# Public site origin — used for canonical + Open Graph URLs (SEO)
VITE_SITE_URL=https://urbanclothing.com

# --- API client tuning (optional; sensible defaults applied) ---
# Request timeout in milliseconds
VITE_API_TIMEOUT=15000
# Max retry attempts for transient (5xx / network) errors
VITE_API_MAX_RETRIES=3
# Base delay (ms) between retries; exponential backoff applied
VITE_API_RETRY_DELAY=1000
# Set to "false" to silence verbose API logs in development
VITE_DEBUG_API=true
